<Window x:Class="Rawr.App.Dialogs.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title, RelativeSource={RelativeSource Self}}"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        MinWidth="280"
>
    <StackPanel Margin="16">
        <TextBlock Text="{Binding Prompt, RelativeSource={RelativeSource AncestorType=Window}}"
                   Margin="0,0,0,8" />
        <TextBox x:Name="InputBox"
                 Width="240"
                 Text="{Binding InputText, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,12" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" IsDefault="True" Click="Ok_Click" MinWidth="64" Margin="0,0,8,0" />
            <Button Content="Cancel" IsCancel="True" Click="Cancel_Click" MinWidth="64" />
        </StackPanel>
    </StackPanel>
</Window>
