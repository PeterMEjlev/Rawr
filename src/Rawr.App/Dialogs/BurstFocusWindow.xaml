<Window x:Class="Rawr.App.Dialogs.BurstFocusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        xmlns:models="clr-namespace:Rawr.Core.Models;assembly=Rawr.Core"
        Title="Burst"
        Height="720" Width="1380"
        MinHeight="400" MinWidth="700"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI"
        FontSize="12">

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CloseCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
        <KeyBinding Key="Right"  Command="{Binding NextCommand,  RelativeSource={RelativeSource AncestorType=Window}}" />
        <KeyBinding Key="Left"   Command="{Binding PrevCommand,  RelativeSource={RelativeSource AncestorType=Window}}" />

        <KeyBinding Key="P"      Command="{Binding TogglePickCommand,   RelativeSource={RelativeSource AncestorType=Window}}" />
        <KeyBinding Key="X"      Command="{Binding ToggleRejectCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
        <KeyBinding Key="U"      Command="{Binding UnflagCommand,       RelativeSource={RelativeSource AncestorType=Window}}" />

        <KeyBinding Key="D0" Command="{Binding SetRatingCommand, RelativeSource={RelativeSource AncestorType=Window}}"><KeyBinding.CommandParameter><sys:Int32>0</sys:Int32></KeyBinding.CommandParameter></KeyBinding>
        <KeyBinding Key="D1" Command="{Binding SetRatingCommand, RelativeSource={RelativeSource AncestorType=Window}}"><KeyBinding.CommandParameter><sys:Int32>1</sys:Int32></KeyBinding.CommandParameter></KeyBinding>
        <KeyBinding Key="D2" Command="{Binding SetRatingCommand, RelativeSource={RelativeSource AncestorType=Window}}"><KeyBinding.CommandParameter><sys:Int32>2</sys:Int32></KeyBinding.CommandParameter></KeyBinding>
        <KeyBinding Key="D3" Command="{Binding SetRatingCommand, RelativeSource={RelativeSource AncestorType=Window}}"><KeyBinding.CommandParameter><sys:Int32>3</sys:Int32></KeyBinding.CommandParameter></KeyBinding>
        <KeyBinding Key="D4" Command="{Binding SetRatingCommand, RelativeSource={RelativeSource AncestorType=Window}}"><KeyBinding.CommandParameter><sys:Int32>4</sys:Int32></KeyBinding.CommandParameter></KeyBinding>
        <KeyBinding Key="D5" Command="{Binding SetRatingCommand, RelativeSource={RelativeSource AncestorType=Window}}"><KeyBinding.CommandParameter><sys:Int32>5</sys:Int32></KeyBinding.CommandParameter></KeyBinding>

        <KeyBinding Key="D6" Command="{Binding SetColorLabelCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{x:Static models:ColorLabel.Red}" />
        <KeyBinding Key="D7" Command="{Binding SetColorLabelCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{x:Static models:ColorLabel.Yellow}" />
        <KeyBinding Key="D8" Command="{Binding SetColorLabelCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{x:Static models:ColorLabel.Green}" />
        <KeyBinding Key="D9" Command="{Binding SetColorLabelCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{x:Static models:ColorLabel.Blue}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="160" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource BgToolbarBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,6">
            <DockPanel LastChildFill="False">
                <TextBlock x:Name="HeaderText"
                           DockPanel.Dock="Left"
                           Foreground="{StaticResource TextBrush}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <TextBlock DockPanel.Dock="Right"
                           Text="Esc to close"
                           Foreground="{StaticResource TextDimBrush}"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- Main preview + metadata panel -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="260" />
            </Grid.ColumnDefinitions>

            <!-- Preview area -->
            <Grid Grid.Column="0" Background="#FF0E0E0E">
                <Border x:Name="PreviewHost"
                        Background="Transparent"
                        ClipToBounds="True"
                        MouseWheel="PreviewHost_MouseWheel"
                        MouseLeftButtonDown="PreviewHost_MouseLeftButtonDown"
                        MouseLeftButtonUp="PreviewHost_MouseLeftButtonUp"
                        MouseMove="PreviewHost_MouseMove">
                    <Image x:Name="PreviewImageElement"
                           Stretch="Uniform"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="Linear"
                           Margin="8"
                           RenderTransformOrigin="0,0">
                        <Image.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="PreviewScale" ScaleX="1" ScaleY="1" />
                                <TranslateTransform x:Name="PreviewTranslate" X="0" Y="0" />
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>
                </Border>

                <!-- Star rating + flag overlay -->
                <StackPanel HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,16,16,0"
                            IsHitTestVisible="False">
                    <Border Background="#80000000"
                            Padding="8,4"
                            CornerRadius="3"
                            Margin="0,0,0,4">
                        <TextBlock x:Name="RatingText"
                                   Foreground="{StaticResource StarBrush}"
                                   FontSize="18"
                                   FontWeight="Bold" />
                    </Border>
                    <Border Background="#80000000"
                            Padding="8,4"
                            CornerRadius="3"
                            x:Name="FlagBadge"
                            Visibility="Collapsed">
                        <TextBlock x:Name="FlagText" Foreground="White" FontSize="12" />
                    </Border>
                </StackPanel>

                <!-- Zoom indicator (bottom-right) -->
                <Border Background="#80000000"
                        Padding="6,2"
                        CornerRadius="3"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,16,16"
                        IsHitTestVisible="False"
                        x:Name="ZoomIndicator"
                        Visibility="Collapsed">
                    <TextBlock x:Name="ZoomIndicatorText"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="11" />
                </Border>
            </Grid>

            <!-- Metadata panel -->
            <Border Grid.Column="1"
                    Background="{StaticResource BgPanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1,0,0,0"
                    Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="PHOTO" Foreground="{StaticResource TextDimBrush}" FontSize="10" Margin="0,0,0,6" />
                        <TextBlock Text="{Binding CurrentPhoto.FileName, FallbackValue='—'}"
                                   FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,8" />

                        <!-- Flag + color label -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="14" Height="14" CornerRadius="2"
                                    Background="{Binding CurrentPhoto.Flag, Converter={StaticResource FlagToBrush}}"
                                    Margin="0,0,8,0" />
                            <TextBlock Text="{Binding CurrentPhoto.Flag, FallbackValue=''}" Margin="0,0,12,0" />
                            <Ellipse Width="10" Height="10"
                                     Fill="{Binding CurrentPhoto.ColorLabel, Converter={StaticResource LabelToBrush}}"
                                     Margin="0,0,6,0" />
                            <TextBlock Text="{Binding CurrentPhoto.ColorLabel, FallbackValue=''}" />
                        </StackPanel>

                        <TextBlock Text="CAMERA" Foreground="{StaticResource TextDimBrush}" FontSize="10" Margin="0,0,0,6" />
                        <TextBlock Text="{Binding CurrentPhoto.Metadata.CameraFormatted, FallbackValue='—'}" Margin="0,0,0,2" />
                        <TextBlock Text="{Binding CurrentPhoto.Metadata.LensModel,       FallbackValue=''}"
                                   Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,12" />

                        <TextBlock Text="EXPOSURE" Foreground="{StaticResource TextDimBrush}" FontSize="10" Margin="0,0,0,6" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="ISO " Foreground="{StaticResource TextDimBrush}" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentPhoto.Metadata.ISOFormatted, FallbackValue='—'}" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Aperture " Foreground="{StaticResource TextDimBrush}" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CurrentPhoto.Metadata.ApertureFormatted, FallbackValue='—'}" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Shutter " Foreground="{StaticResource TextDimBrush}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CurrentPhoto.Metadata.ShutterSpeedFormatted, FallbackValue='—'}" />
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Focal " Foreground="{StaticResource TextDimBrush}" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding CurrentPhoto.Metadata.FocalLengthFormatted, FallbackValue='—'}" />
                        </Grid>

                        <TextBlock Text="BURST" Foreground="{StaticResource TextDimBrush}" FontSize="10" Margin="0,0,0,6"
                                   Visibility="{Binding CurrentPhoto.BurstBadge, Converter={StaticResource NullToVisibility}}" />
                        <TextBlock Text="{Binding CurrentPhoto.BurstBadge, FallbackValue=''}" Margin="0,0,0,12"
                                   Visibility="{Binding CurrentPhoto.BurstBadge, Converter={StaticResource NullToVisibility}}" />

                        <TextBlock Text="DATE" Foreground="{StaticResource TextDimBrush}" FontSize="10" Margin="0,0,0,6" />
                        <TextBlock Text="{Binding CurrentPhoto.Metadata.CaptureDateFormatted, FallbackValue='—'}" Margin="0,0,0,12" />

                        <TextBlock Text="FILE" Foreground="{StaticResource TextDimBrush}" FontSize="10" Margin="0,0,0,6" />
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Type "       Foreground="{StaticResource TextDimBrush}" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentPhoto.Extension, FallbackValue=''}" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Dimensions " Foreground="{StaticResource TextDimBrush}" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CurrentPhoto.Metadata.DimensionsFormatted, FallbackValue='—'}" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Size "       Foreground="{StaticResource TextDimBrush}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CurrentPhoto.Metadata.FileSizeFormatted, FallbackValue='—'}" />
                        </Grid>
                        <TextBlock Text="{Binding CurrentPhoto.FilePath, FallbackValue=''}"
                                   Foreground="{StaticResource TextDimBrush}"
                                   TextWrapping="Wrap" FontSize="10" Margin="0,4,0,0" />

                        <Separator Margin="0,16" />

                        <TextBlock Text="SHORTCUTS" Foreground="{StaticResource TextDimBrush}" FontSize="10" Margin="0,0,0,6" />
                        <TextBlock Text="←/→  Navigate" Margin="0,1" />
                        <TextBlock Text="0–5  Rating" Margin="0,1" />
                        <TextBlock Text="6–9  Color label" Margin="0,1" />
                        <TextBlock Text="P / X  Pick / Reject" Margin="0,1" />
                        <TextBlock Text="U  Unflag" Margin="0,1" />
                        <TextBlock Text="Esc  Close" Margin="0,1" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Filmstrip -->
        <Border Grid.Row="2"
                Background="{StaticResource BgFilmstripBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <ListBox x:Name="Strip"
                     ItemContainerStyle="{StaticResource FilmstripItemStyle}"
                     SelectionChanged="Strip_SelectionChanged"
                     PreviewMouseWheel="Strip_PreviewMouseWheel"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:PhotoItem}">
                        <Grid Width="140">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#FF0E0E0E">
                                <Grid>
                                    <Image Source="{Binding ThumbnailJpeg, Converter={StaticResource ThumbBytesToImage}}"
                                           Stretch="Uniform"
                                           SnapsToDevicePixels="True"
                                           RenderOptions.BitmapScalingMode="LowQuality" />
                                    <Rectangle Width="3"
                                               HorizontalAlignment="Left"
                                               Fill="{Binding Flag, Converter={StaticResource FlagToBrush}}" />
                                    <Ellipse Width="8" Height="8"
                                             HorizontalAlignment="Right" VerticalAlignment="Top"
                                             Margin="0,4,4,0"
                                             Fill="{Binding ColorLabel, Converter={StaticResource LabelToBrush}}" />
                                    <Border HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                            Background="#A0000000"
                                            Padding="4,1" Margin="2"
                                            CornerRadius="2"
                                            Visibility="{Binding Rating, Converter={StaticResource NullToVisibility}}">
                                        <TextBlock Text="{Binding Rating, Converter={StaticResource RatingToStars}}"
                                                   Foreground="{StaticResource StarBrush}"
                                                   FontSize="10" />
                                    </Border>
                                </Grid>
                            </Border>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding FileName}"
                                       Foreground="{StaticResource TextDimBrush}"
                                       FontSize="10"
                                       TextTrimming="CharacterEllipsis"
                                       Padding="2,2,2,0" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </Grid>
</Window>
