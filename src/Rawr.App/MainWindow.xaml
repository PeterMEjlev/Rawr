<Window x:Class="Rawr.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        xmlns:vm="clr-namespace:Rawr.App.ViewModels"
        xmlns:models="clr-namespace:Rawr.Core.Models;assembly=Rawr.Core"
        xmlns:controls="clr-namespace:Rawr.App.Controls"
        mc:Ignorable="d"
        Title="RAWR — RAW Photo Culling"
        Height="800" Width="1280"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.InputBindings>
        <!-- Folder / file ops -->
        <KeyBinding Modifiers="Control" Key="O" Command="{Binding OpenFolderCommand}" />
        <KeyBinding Modifiers="Control" Key="E" Command="{Binding ExportFileListCommand}" />
        <KeyBinding Modifiers="Control" Key="C" Command="{Binding CopyPickedCommand}" />

        <!-- Navigation -->
        <KeyBinding Key="Right" Command="{Binding NextPhotoCommand}" />
        <KeyBinding Key="Left" Command="{Binding PreviousPhotoCommand}" />
        <KeyBinding Key="Down" Command="{Binding NextPhotoCommand}" />
        <KeyBinding Key="Up" Command="{Binding PreviousPhotoCommand}" />
        <KeyBinding Modifiers="Control" Key="Right" Command="{Binding NextBurstCommand}" />
        <KeyBinding Modifiers="Control" Key="Left" Command="{Binding PreviousBurstCommand}" />

        <!-- Flags -->
        <KeyBinding Key="P" Command="{Binding TogglePickCommand}" />
        <KeyBinding Key="X" Command="{Binding ToggleRejectCommand}" />
        <KeyBinding Key="U" Command="{Binding UnflagCommand}" />
        <KeyBinding Modifiers="Shift" Key="P" Command="{Binding PickAndAdvanceCommand}" />
        <KeyBinding Modifiers="Shift" Key="X" Command="{Binding RejectAndAdvanceCommand}" />

        <!-- Ratings (0-5) -->
        <KeyBinding Key="D0" Command="{Binding SetRatingCommand}">
            <KeyBinding.CommandParameter><sys:Int32>0</sys:Int32></KeyBinding.CommandParameter>
        </KeyBinding>
        <KeyBinding Key="D1" Command="{Binding SetRatingCommand}">
            <KeyBinding.CommandParameter><sys:Int32>1</sys:Int32></KeyBinding.CommandParameter>
        </KeyBinding>
        <KeyBinding Key="D2" Command="{Binding SetRatingCommand}">
            <KeyBinding.CommandParameter><sys:Int32>2</sys:Int32></KeyBinding.CommandParameter>
        </KeyBinding>
        <KeyBinding Key="D3" Command="{Binding SetRatingCommand}">
            <KeyBinding.CommandParameter><sys:Int32>3</sys:Int32></KeyBinding.CommandParameter>
        </KeyBinding>
        <KeyBinding Key="D4" Command="{Binding SetRatingCommand}">
            <KeyBinding.CommandParameter><sys:Int32>4</sys:Int32></KeyBinding.CommandParameter>
        </KeyBinding>
        <KeyBinding Key="D5" Command="{Binding SetRatingCommand}">
            <KeyBinding.CommandParameter><sys:Int32>5</sys:Int32></KeyBinding.CommandParameter>
        </KeyBinding>

        <!-- Color labels (6-9 like Lightroom) -->
        <KeyBinding Key="D6" Command="{Binding SetColorLabelCommand}"
                    CommandParameter="{x:Static models:ColorLabel.Red}" />
        <KeyBinding Key="D7" Command="{Binding SetColorLabelCommand}"
                    CommandParameter="{x:Static models:ColorLabel.Yellow}" />
        <KeyBinding Key="D8" Command="{Binding SetColorLabelCommand}"
                    CommandParameter="{x:Static models:ColorLabel.Green}" />
        <KeyBinding Key="D9" Command="{Binding SetColorLabelCommand}"
                    CommandParameter="{x:Static models:ColorLabel.Blue}" />

        <!-- Delete -->
        <KeyBinding Key="Delete" Command="{Binding DeletePhotoCommand}" />

        <!-- Filters -->
        <KeyBinding Modifiers="Control+Shift" Key="X" Command="{Binding ClearFiltersCommand}" />

        <!-- Burst collapse toggle -->
        <KeyBinding Key="G" Command="{Binding ToggleBurstCollapseCommand}" />

        <!-- Custom group assignment (Shift+1 through Shift+0 = group index 0–9) -->
        <KeyBinding Modifiers="Shift" Key="D1" Command="{Binding AssignTagByIndexCommand}">
            <KeyBinding.CommandParameter><sys:Int32>0</sys:Int32></KeyBinding.CommandParameter>
        </KeyBinding>
        <KeyBinding Modifiers="Shift" Key="D2" Command="{Binding AssignTagByIndexCommand}">
            <KeyBinding.CommandParameter><sys:Int32>1</sys:Int32></KeyBinding.CommandParameter>
        </KeyBinding>
        <KeyBinding Modifiers="Shift" Key="D3" Command="{Binding AssignTagByIndexCommand}">
            <KeyBinding.CommandParameter><sys:Int32>2</sys:Int32></KeyBinding.CommandParameter>
        </KeyBinding>
        <KeyBinding Modifiers="Shift" Key="D4" Command="{Binding AssignTagByIndexCommand}">
            <KeyBinding.CommandParameter><sys:Int32>3</sys:Int32></KeyBinding.CommandParameter>
        </KeyBinding>
        <KeyBinding Modifiers="Shift" Key="D5" Command="{Binding AssignTagByIndexCommand}">
            <KeyBinding.CommandParameter><sys:Int32>4</sys:Int32></KeyBinding.CommandParameter>
        </KeyBinding>
        <KeyBinding Modifiers="Shift" Key="D6" Command="{Binding AssignTagByIndexCommand}">
            <KeyBinding.CommandParameter><sys:Int32>5</sys:Int32></KeyBinding.CommandParameter>
        </KeyBinding>
        <KeyBinding Modifiers="Shift" Key="D7" Command="{Binding AssignTagByIndexCommand}">
            <KeyBinding.CommandParameter><sys:Int32>6</sys:Int32></KeyBinding.CommandParameter>
        </KeyBinding>
        <KeyBinding Modifiers="Shift" Key="D8" Command="{Binding AssignTagByIndexCommand}">
            <KeyBinding.CommandParameter><sys:Int32>7</sys:Int32></KeyBinding.CommandParameter>
        </KeyBinding>
        <KeyBinding Modifiers="Shift" Key="D9" Command="{Binding AssignTagByIndexCommand}">
            <KeyBinding.CommandParameter><sys:Int32>8</sys:Int32></KeyBinding.CommandParameter>
        </KeyBinding>
        <KeyBinding Modifiers="Shift" Key="D0" Command="{Binding AssignTagByIndexCommand}">
            <KeyBinding.CommandParameter><sys:Int32>9</sys:Int32></KeyBinding.CommandParameter>
        </KeyBinding>
    </Window.InputBindings>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />                              <!-- Toolbar -->
            <RowDefinition Height="*" />                                 <!-- Main split: preview + metadata -->
            <RowDefinition Height="4" />                                 <!-- Filmstrip splitter -->
            <RowDefinition Height="148" MinHeight="80" MaxHeight="400"/> <!-- Filmstrip -->
            <RowDefinition Height="Auto" />                              <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ================ TOOLBAR ================ -->
        <Border Grid.Row="0"
                Background="{StaticResource BgToolbarBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <DockPanel LastChildFill="False">
                <Button DockPanel.Dock="Left" Content="📂 Open Folder…" Command="{Binding OpenFolderCommand}" Margin="0,0,8,0" ToolTip="Ctrl+O" />
                <Border DockPanel.Dock="Left" Width="1" Background="{StaticResource BorderBrush}" Margin="4,4" />

                <!-- Filter dropdown -->
                <Grid DockPanel.Dock="Left" Margin="0,0,8,0">
                    <ToggleButton x:Name="FilterToggleButton"
                                  IsChecked="{Binding IsOpen, ElementName=FilterPopup, Mode=TwoWay}"
                                  ToolTip="Filter photos by rating, flag, color, burst, or tag  —  Ctrl+Shift+X to clear all filters">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasActiveFilters}" Value="True">
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                        🔍 Filter
                    </ToggleButton>

                    <Popup x:Name="FilterPopup"
                           StaysOpen="False"
                           Placement="Bottom"
                           PlacementTarget="{Binding ElementName=FilterToggleButton}"
                           AllowsTransparency="True">
                        <Border Background="{StaticResource BgControlBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Padding="10,8">
                            <StackPanel>

                                <!-- Rating -->
                                <TextBlock Text="RATING" FontSize="10" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,5" />
                                <StackPanel Margin="0,0,0,10">

                                    <!-- Any + mode toggle -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                        <Button Content="Any" Command="{Binding ClearRatingFilterCommand}" Margin="0,0,3,0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RatingFilterMode}" Value="Any">
                                                            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Content="{Binding RatingModeLabel}" Command="{Binding CycleRatingModeCommand}" Width="28" />
                                    </StackPanel>

                                    <!-- Star buttons 0–5 -->
                                    <StackPanel Orientation="Horizontal">
                                        <Button Command="{Binding SetRatingValueCommand}" Margin="0,0,3,0">
                                            <Button.CommandParameter><sys:Int32>0</sys:Int32></Button.CommandParameter>
                                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Style.Triggers><DataTrigger Binding="{Binding ActiveRatingValue}" Value="0"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger></Style.Triggers></Style></Button.Style>
                                            0★
                                        </Button>
                                        <Button Command="{Binding SetRatingValueCommand}" Margin="0,0,3,0">
                                            <Button.CommandParameter><sys:Int32>1</sys:Int32></Button.CommandParameter>
                                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Style.Triggers><DataTrigger Binding="{Binding ActiveRatingValue}" Value="1"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger></Style.Triggers></Style></Button.Style>
                                            1★
                                        </Button>
                                        <Button Command="{Binding SetRatingValueCommand}" Margin="0,0,3,0">
                                            <Button.CommandParameter><sys:Int32>2</sys:Int32></Button.CommandParameter>
                                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Style.Triggers><DataTrigger Binding="{Binding ActiveRatingValue}" Value="2"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger></Style.Triggers></Style></Button.Style>
                                            2★
                                        </Button>
                                        <Button Command="{Binding SetRatingValueCommand}" Margin="0,0,3,0">
                                            <Button.CommandParameter><sys:Int32>3</sys:Int32></Button.CommandParameter>
                                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Style.Triggers><DataTrigger Binding="{Binding ActiveRatingValue}" Value="3"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger></Style.Triggers></Style></Button.Style>
                                            3★
                                        </Button>
                                        <Button Command="{Binding SetRatingValueCommand}" Margin="0,0,3,0">
                                            <Button.CommandParameter><sys:Int32>4</sys:Int32></Button.CommandParameter>
                                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Style.Triggers><DataTrigger Binding="{Binding ActiveRatingValue}" Value="4"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger></Style.Triggers></Style></Button.Style>
                                            4★
                                        </Button>
                                        <Button Command="{Binding SetRatingValueCommand}">
                                            <Button.CommandParameter><sys:Int32>5</sys:Int32></Button.CommandParameter>
                                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Style.Triggers><DataTrigger Binding="{Binding ActiveRatingValue}" Value="5"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger></Style.Triggers></Style></Button.Style>
                                            5★
                                        </Button>
                                    </StackPanel>

                                </StackPanel>

                                <!-- Flag -->
                                <TextBlock Text="FLAG" FontSize="10" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,5" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Button Content="Any" Command="{Binding ClearFlagFilterCommand}" Margin="0,0,3,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FlagFilter}" Value="{x:Null}">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Pick" Command="{Binding SetFlagFilterCommand}"
                                            CommandParameter="{x:Static models:CullFlag.Pick}" Margin="0,0,3,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FlagFilter}" Value="{x:Static models:CullFlag.Pick}">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Reject" Command="{Binding SetFlagFilterCommand}"
                                            CommandParameter="{x:Static models:CullFlag.Reject}" Margin="0,0,3,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FlagFilter}" Value="{x:Static models:CullFlag.Reject}">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Unflagged" Command="{Binding SetFlagFilterCommand}"
                                            CommandParameter="{x:Static models:CullFlag.Unflagged}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FlagFilter}" Value="{x:Static models:CullFlag.Unflagged}">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>

                                <!-- Color -->
                                <TextBlock Text="COLOR" FontSize="10" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,5" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Button Content="Any" Command="{Binding ClearColorLabelFilterCommand}" Margin="0,0,3,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ColorLabelFilter}" Value="{x:Null}">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="No Color" Command="{Binding SetColorLabelFilterCommand}"
                                            CommandParameter="{x:Static models:ColorLabel.None}" Margin="0,0,3,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ColorLabelFilter}" Value="{x:Static models:ColorLabel.None}">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Command="{Binding SetColorLabelFilterCommand}"
                                            CommandParameter="{x:Static models:ColorLabel.Red}" Margin="0,0,3,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ColorLabelFilter}" Value="{x:Static models:ColorLabel.Red}">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" Margin="0,0,5,0"
                                                     Fill="{Binding Source={x:Static models:ColorLabel.Red}, Converter={StaticResource LabelToBrush}}" />
                                            <TextBlock Text="Red" />
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding SetColorLabelFilterCommand}"
                                            CommandParameter="{x:Static models:ColorLabel.Yellow}" Margin="0,0,3,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ColorLabelFilter}" Value="{x:Static models:ColorLabel.Yellow}">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" Margin="0,0,5,0"
                                                     Fill="{Binding Source={x:Static models:ColorLabel.Yellow}, Converter={StaticResource LabelToBrush}}" />
                                            <TextBlock Text="Yellow" />
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding SetColorLabelFilterCommand}"
                                            CommandParameter="{x:Static models:ColorLabel.Green}" Margin="0,0,3,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ColorLabelFilter}" Value="{x:Static models:ColorLabel.Green}">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" Margin="0,0,5,0"
                                                     Fill="{Binding Source={x:Static models:ColorLabel.Green}, Converter={StaticResource LabelToBrush}}" />
                                            <TextBlock Text="Green" />
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding SetColorLabelFilterCommand}"
                                            CommandParameter="{x:Static models:ColorLabel.Blue}" Margin="0,0,3,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ColorLabelFilter}" Value="{x:Static models:ColorLabel.Blue}">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" Margin="0,0,5,0"
                                                     Fill="{Binding Source={x:Static models:ColorLabel.Blue}, Converter={StaticResource LabelToBrush}}" />
                                            <TextBlock Text="Blue" />
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding SetColorLabelFilterCommand}"
                                            CommandParameter="{x:Static models:ColorLabel.Purple}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ColorLabelFilter}" Value="{x:Static models:ColorLabel.Purple}">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" Margin="0,0,5,0"
                                                     Fill="{Binding Source={x:Static models:ColorLabel.Purple}, Converter={StaticResource LabelToBrush}}" />
                                            <TextBlock Text="Purple" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <!-- Bursts -->
                                <TextBlock Text="BURSTS" FontSize="10" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,5" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Button Content="Any" Command="{Binding ClearBurstFilterCommand}" Margin="0,0,3,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding BurstFilter}" Value="Any">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Bursts only"
                                            Command="{Binding SetBurstFilterCommand}"
                                            CommandParameter="{x:Static vm:BurstFilterMode.OnlyInBursts}"
                                            Margin="0,0,3,0"
                                            ToolTip="Show only photos that are part of a burst">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding BurstFilter}" Value="OnlyInBursts">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Singles only"
                                            Command="{Binding SetBurstFilterCommand}"
                                            CommandParameter="{x:Static vm:BurstFilterMode.OnlySingles}"
                                            ToolTip="Hide photos that are part of a burst">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding BurstFilter}" Value="OnlySingles">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>

                                <!-- Type -->
                                <TextBlock Text="TYPE" FontSize="10" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,5" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Button Content="Any" Command="{Binding ClearImageTypeFilterCommand}" Margin="0,0,3,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ImageTypeFilter}" Value="Any">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="RAW only"
                                            Command="{Binding SetImageTypeFilterCommand}"
                                            CommandParameter="{x:Static vm:ImageTypeFilterMode.RawOnly}"
                                            Margin="0,0,3,0"
                                            ToolTip="Show only RAW files">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ImageTypeFilter}" Value="RawOnly">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="JPG only"
                                            Command="{Binding SetImageTypeFilterCommand}"
                                            CommandParameter="{x:Static vm:ImageTypeFilterMode.JpegOnly}"
                                            Margin="0,0,3,0"
                                            ToolTip="Show only JPEG files">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ImageTypeFilter}" Value="JpegOnly">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Video only"
                                            Command="{Binding SetImageTypeFilterCommand}"
                                            CommandParameter="{x:Static vm:ImageTypeFilterMode.VideoOnly}"
                                            ToolTip="Show only videos">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ImageTypeFilter}" Value="VideoOnly">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>

                                <!-- Groups -->
                                <TextBlock Text="TAGS" FontSize="10" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,5" />
                                <WrapPanel Margin="0,0,0,6">
                                    <Button Content="Any" Command="{Binding ClearTagFilterCommand}" Margin="0,0,3,3">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TagFilter}" Value="{x:Null}">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <ItemsControl ItemsSource="{Binding Tags}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding Name}"
                                                        Command="{Binding DataContext.SetTagFilterCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Margin="0,0,3,3">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                            <Style.Triggers>
                                                                <DataTrigger Value="True">
                                                                    <DataTrigger.Binding>
                                                                        <MultiBinding Converter="{StaticResource Equality}">
                                                                            <Binding Path="DataContext.TagFilter" RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                                            <Binding />
                                                                        </MultiBinding>
                                                                    </DataTrigger.Binding>
                                                                    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <Button.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="Rename tag…"
                                                                      Command="{Binding PlacementTarget.Tag.RenameTagCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                            <MenuItem Header="Delete tag"
                                                                      Command="{Binding PlacementTarget.Tag.DeleteTagCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                        </ContextMenu>
                                                    </Button.ContextMenu>
                                                    <Button.Tag>
                                                        <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                    </Button.Tag>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Button Content="+" Command="{Binding CreateTagCommand}" ToolTip="Create new tag" Margin="0,0,0,3" />
                                </WrapPanel>

                                <Separator Margin="0,2,0,8" />
                                <Button Content="Clear All Filters" Command="{Binding ClearFiltersCommand}"
                                        HorizontalAlignment="Stretch" ToolTip="Ctrl+Shift+X" />

                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>

                <Border DockPanel.Dock="Left" Width="1" Background="{StaticResource BorderBrush}" Margin="4,4" />

                <!-- Burst collapse toggle -->
                <ToggleButton DockPanel.Dock="Left"
                              IsChecked="{Binding BurstCollapsed}"
                              Margin="0,0,8,0"
                              ToolTip="G — collapse bursts to a single tile (double-click a stack to focus)">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
                            <!-- Default (unchecked = expanded): pressing collapses -->
                            <Setter Property="Content" Value="🗂 Collapse Bursts" />
                            <Style.Triggers>
                                <!-- Checked (collapsed): pressing expands -->
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Content" Value="🗂 Expand Bursts" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>

                <Border DockPanel.Dock="Left" Width="1" Background="{StaticResource BorderBrush}" Margin="4,4" />

                <!-- Tags management button -->
                <Grid DockPanel.Dock="Left" Margin="0,0,8,0">
                    <ToggleButton x:Name="TagsToggleButton"
                                  IsChecked="{Binding IsOpen, ElementName=TagsPopup, Mode=TwoWay}"
                                  Content="🏷 Tags"
                                  ToolTip="Create and filter by tags  —  Shift+1 through Shift+0 to assign tags to selected photo" />
                    <Popup x:Name="TagsPopup"
                           StaysOpen="False"
                           Placement="Bottom"
                           PlacementTarget="{Binding ElementName=TagsToggleButton}"
                           AllowsTransparency="True">
                        <Border Background="{StaticResource BgControlBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Padding="10,8"
                                MinWidth="200">
                            <StackPanel>
                                <TextBlock Text="TAGS" FontSize="10" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,8" />
                                <ItemsControl ItemsSource="{Binding Tags}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel Margin="0,0,0,4">
                                                <Button DockPanel.Dock="Right"
                                                        Content="✕"
                                                        Padding="6,2"
                                                        Margin="4,0,0,0"
                                                        Command="{Binding DataContext.DeleteTagCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="Delete tag" />
                                                <Button DockPanel.Dock="Right"
                                                        Content="✎"
                                                        Padding="6,2"
                                                        Margin="4,0,0,0"
                                                        Command="{Binding DataContext.RenameTagCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="Rename tag" />
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                            </DockPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Separator Margin="0,4,0,8" />
                                <Button Content="+ New Tag" Command="{Binding CreateTagCommand}"
                                        HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>

                <Border DockPanel.Dock="Left" Width="1" Background="{StaticResource BorderBrush}" Margin="4,4" />

                <TextBlock DockPanel.Dock="Left"
                           Text="Sort"
                           Foreground="{StaticResource TextDimBrush}"
                           Margin="0,0,6,0" />
                <ComboBox DockPanel.Dock="Left"
                          SelectedValue="{Binding SortField, Mode=TwoWay}"
                          SelectedValuePath="Tag"
                          MinWidth="70"
                          Margin="0,0,4,0"
                          ToolTip="Sort photos by this field">
                    <ComboBoxItem Content="Name"   Tag="{x:Static vm:SortField.FileName}" />
                    <ComboBoxItem Content="Rating" Tag="{x:Static vm:SortField.Rating}" />
                    <ComboBoxItem Content="Date"   Tag="{x:Static vm:SortField.CaptureDate}" />
                    <ComboBoxItem Content="Color"  Tag="{x:Static vm:SortField.ColorLabel}" />
                    <ComboBoxItem Content="Flag"   Tag="{x:Static vm:SortField.Flag}" />
                    <ComboBoxItem Content="Burst"  Tag="{x:Static vm:SortField.Burst}" />
                    <ComboBoxItem Content="Type"   Tag="{x:Static vm:SortField.ImageType}" />
                </ComboBox>
                <Button DockPanel.Dock="Left" Content="{Binding SortDirectionLabel}" Command="{Binding ToggleSortDirectionCommand}" Margin="0,0,8,0" ToolTip="Reverse sort order" />

                <Border DockPanel.Dock="Left" Width="1" Background="{StaticResource BorderBrush}" Margin="4,4" />

                <!-- Copy dropdown -->
                <Grid DockPanel.Dock="Left" Margin="0,0,4,0">
                    <ToggleButton x:Name="CopyToggleButton"
                                  IsChecked="{Binding IsOpen, ElementName=CopyPopup, Mode=TwoWay}"
                                  Content="📋 Copy…"
                                  ToolTip="Choose which photos to copy" />
                    <Popup x:Name="CopyPopup"
                           StaysOpen="False"
                           Placement="Bottom"
                           PlacementTarget="{Binding ElementName=CopyToggleButton}"
                           AllowsTransparency="True">
                        <Border Background="{StaticResource BgControlBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Padding="10,8">
                            <StackPanel>

                                <!-- Rating -->
                                <TextBlock Text="RATING" FontSize="10" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,5" />
                                <StackPanel Margin="0,0,0,10">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                        <Button Content="Any" Command="{Binding ClearCopyRatingFilterCommand}" Margin="0,0,3,0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CopyRatingFilterMode}" Value="Any">
                                                            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Content="{Binding CopyRatingModeLabel}" Command="{Binding CycleCopyRatingModeCommand}" Width="28" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Command="{Binding SetCopyRatingValueCommand}" Margin="0,0,3,0">
                                            <Button.CommandParameter><sys:Int32>0</sys:Int32></Button.CommandParameter>
                                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Style.Triggers><DataTrigger Binding="{Binding CopyActiveRatingValue}" Value="0"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger></Style.Triggers></Style></Button.Style>
                                            0★
                                        </Button>
                                        <Button Command="{Binding SetCopyRatingValueCommand}" Margin="0,0,3,0">
                                            <Button.CommandParameter><sys:Int32>1</sys:Int32></Button.CommandParameter>
                                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Style.Triggers><DataTrigger Binding="{Binding CopyActiveRatingValue}" Value="1"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger></Style.Triggers></Style></Button.Style>
                                            1★
                                        </Button>
                                        <Button Command="{Binding SetCopyRatingValueCommand}" Margin="0,0,3,0">
                                            <Button.CommandParameter><sys:Int32>2</sys:Int32></Button.CommandParameter>
                                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Style.Triggers><DataTrigger Binding="{Binding CopyActiveRatingValue}" Value="2"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger></Style.Triggers></Style></Button.Style>
                                            2★
                                        </Button>
                                        <Button Command="{Binding SetCopyRatingValueCommand}" Margin="0,0,3,0">
                                            <Button.CommandParameter><sys:Int32>3</sys:Int32></Button.CommandParameter>
                                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Style.Triggers><DataTrigger Binding="{Binding CopyActiveRatingValue}" Value="3"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger></Style.Triggers></Style></Button.Style>
                                            3★
                                        </Button>
                                        <Button Command="{Binding SetCopyRatingValueCommand}" Margin="0,0,3,0">
                                            <Button.CommandParameter><sys:Int32>4</sys:Int32></Button.CommandParameter>
                                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Style.Triggers><DataTrigger Binding="{Binding CopyActiveRatingValue}" Value="4"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger></Style.Triggers></Style></Button.Style>
                                            4★
                                        </Button>
                                        <Button Command="{Binding SetCopyRatingValueCommand}">
                                            <Button.CommandParameter><sys:Int32>5</sys:Int32></Button.CommandParameter>
                                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Style.Triggers><DataTrigger Binding="{Binding CopyActiveRatingValue}" Value="5"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger></Style.Triggers></Style></Button.Style>
                                            5★
                                        </Button>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Flag -->
                                <TextBlock Text="FLAG" FontSize="10" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,5" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Button Content="Any" Command="{Binding ClearCopyFlagFilterCommand}" Margin="0,0,3,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CopyFlagFilter}" Value="{x:Null}">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Pick" Command="{Binding SetCopyFlagFilterCommand}"
                                            CommandParameter="{x:Static models:CullFlag.Pick}" Margin="0,0,3,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CopyFlagFilter}" Value="{x:Static models:CullFlag.Pick}">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Reject" Command="{Binding SetCopyFlagFilterCommand}"
                                            CommandParameter="{x:Static models:CullFlag.Reject}" Margin="0,0,3,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CopyFlagFilter}" Value="{x:Static models:CullFlag.Reject}">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Unflagged" Command="{Binding SetCopyFlagFilterCommand}"
                                            CommandParameter="{x:Static models:CullFlag.Unflagged}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CopyFlagFilter}" Value="{x:Static models:CullFlag.Unflagged}">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>

                                <!-- Color -->
                                <TextBlock Text="COLOR" FontSize="10" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,5" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Button Content="Any" Command="{Binding ClearCopyColorLabelFilterCommand}" Margin="0,0,3,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CopyColorLabelFilter}" Value="{x:Null}">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="No Color" Command="{Binding SetCopyColorLabelFilterCommand}"
                                            CommandParameter="{x:Static models:ColorLabel.None}" Margin="0,0,3,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CopyColorLabelFilter}" Value="{x:Static models:ColorLabel.None}">
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Command="{Binding SetCopyColorLabelFilterCommand}"
                                            CommandParameter="{x:Static models:ColorLabel.Red}" Margin="0,0,3,0">
                                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Style.Triggers><DataTrigger Binding="{Binding CopyColorLabelFilter}" Value="{x:Static models:ColorLabel.Red}"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger></Style.Triggers></Style></Button.Style>
                                        <StackPanel Orientation="Horizontal"><Ellipse Width="8" Height="8" Margin="0,0,5,0" Fill="{Binding Source={x:Static models:ColorLabel.Red}, Converter={StaticResource LabelToBrush}}" /><TextBlock Text="Red" /></StackPanel>
                                    </Button>
                                    <Button Command="{Binding SetCopyColorLabelFilterCommand}"
                                            CommandParameter="{x:Static models:ColorLabel.Yellow}" Margin="0,0,3,0">
                                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Style.Triggers><DataTrigger Binding="{Binding CopyColorLabelFilter}" Value="{x:Static models:ColorLabel.Yellow}"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger></Style.Triggers></Style></Button.Style>
                                        <StackPanel Orientation="Horizontal"><Ellipse Width="8" Height="8" Margin="0,0,5,0" Fill="{Binding Source={x:Static models:ColorLabel.Yellow}, Converter={StaticResource LabelToBrush}}" /><TextBlock Text="Yellow" /></StackPanel>
                                    </Button>
                                    <Button Command="{Binding SetCopyColorLabelFilterCommand}"
                                            CommandParameter="{x:Static models:ColorLabel.Green}" Margin="0,0,3,0">
                                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Style.Triggers><DataTrigger Binding="{Binding CopyColorLabelFilter}" Value="{x:Static models:ColorLabel.Green}"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger></Style.Triggers></Style></Button.Style>
                                        <StackPanel Orientation="Horizontal"><Ellipse Width="8" Height="8" Margin="0,0,5,0" Fill="{Binding Source={x:Static models:ColorLabel.Green}, Converter={StaticResource LabelToBrush}}" /><TextBlock Text="Green" /></StackPanel>
                                    </Button>
                                    <Button Command="{Binding SetCopyColorLabelFilterCommand}"
                                            CommandParameter="{x:Static models:ColorLabel.Blue}" Margin="0,0,3,0">
                                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Style.Triggers><DataTrigger Binding="{Binding CopyColorLabelFilter}" Value="{x:Static models:ColorLabel.Blue}"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger></Style.Triggers></Style></Button.Style>
                                        <StackPanel Orientation="Horizontal"><Ellipse Width="8" Height="8" Margin="0,0,5,0" Fill="{Binding Source={x:Static models:ColorLabel.Blue}, Converter={StaticResource LabelToBrush}}" /><TextBlock Text="Blue" /></StackPanel>
                                    </Button>
                                    <Button Command="{Binding SetCopyColorLabelFilterCommand}"
                                            CommandParameter="{x:Static models:ColorLabel.Purple}">
                                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Style.Triggers><DataTrigger Binding="{Binding CopyColorLabelFilter}" Value="{x:Static models:ColorLabel.Purple}"><Setter Property="Background" Value="{StaticResource AccentBrush}" /></DataTrigger></Style.Triggers></Style></Button.Style>
                                        <StackPanel Orientation="Horizontal"><Ellipse Width="8" Height="8" Margin="0,0,5,0" Fill="{Binding Source={x:Static models:ColorLabel.Purple}, Converter={StaticResource LabelToBrush}}" /><TextBlock Text="Purple" /></StackPanel>
                                    </Button>
                                </StackPanel>

                                <Separator Margin="0,2,0,8" />
                                <Button Content="📋 Copy…" Command="{Binding CopyPickedCommand}"
                                        HorizontalAlignment="Stretch" ToolTip="Ctrl+C — copy matching photos to a folder" />

                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
                <Button DockPanel.Dock="Left" Content="📝 Export List…"     Command="{Binding ExportFileListCommand}" Margin="0,0,4,0" ToolTip="Ctrl+E — export list of picked file paths" />
                <Button DockPanel.Dock="Left" Content="🗑 Delete Rejected…" Command="{Binding DeleteAllRejectedCommand}" Margin="0,0,4,0" ToolTip="Move all rejected photos to the Recycle Bin" />

                <Border DockPanel.Dock="Left" Width="1" Background="{StaticResource BorderBrush}" Margin="4,4" />

                <!-- View dropdown -->
                <Grid DockPanel.Dock="Left" Margin="0,0,8,0">
                    <ToggleButton x:Name="ViewToggleButton"
                                  IsChecked="{Binding IsOpen, ElementName=ViewPopup, Mode=TwoWay}"
                                  ToolTip="Show or hide the thumbnail grid and filmstrip panels">
                        View
                    </ToggleButton>
                    <Popup x:Name="ViewPopup"
                           StaysOpen="False"
                           Placement="Bottom"
                           PlacementTarget="{Binding ElementName=ViewToggleButton}"
                           AllowsTransparency="True">
                        <Border Background="{StaticResource BgControlBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Padding="10,8">
                            <StackPanel>
                                <TextBlock Text="PANELS" FontSize="10" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,6" />
                                <CheckBox Content="Grid" IsChecked="{Binding ShowGrid}" Margin="0,0,0,4" />
                                <CheckBox Content="Filmstrip" IsChecked="{Binding ShowFilmstrip}" />
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>

                <!-- Settings button -->
                <Button DockPanel.Dock="Right"
                        Content="⚙"
                        Click="Settings_Click"
                        Margin="0,0,4,0"
                        ToolTip="Settings" />

                <!-- Extractor indicator -->
                <Border DockPanel.Dock="Right"
                        Background="#33FFFFFF"
                        CornerRadius="3"
                        Padding="6,2"
                        Margin="8,0,0,0"
                        ToolTip="Preview extractor in use. LibRaw = fast embedded JPEG; WIC = Windows codec (slower, needs Raw Image Extension)">
                    <TextBlock Text="{Binding ExtractorName}" FontSize="10" Foreground="{StaticResource TextDimBrush}" />
                </Border>

                <!-- Right-aligned filter description -->
                <TextBlock DockPanel.Dock="Right" Margin="8,0" Foreground="{StaticResource TextDimBrush}">
                    <Run Text="Filter: " />
                    <Run Text="{Binding FilterDescription, Mode=OneWay}" Foreground="{StaticResource TextBrush}" />
                    <Run Text="    " />
                    <Run Text="{Binding VisibleCount, Mode=OneWay}" />
                    <Run Text=" / " />
                    <Run Text="{Binding TotalCount, Mode=OneWay}" />
                    <Run Text=" photos" />
                </TextBlock>
            </DockPanel>
        </Border>

        <!-- ================ MAIN SPLIT (grid panel + preview + metadata) ================ -->
        <Grid x:Name="MainSplitGrid" Grid.Row="1" Background="{StaticResource BgBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="100" MaxWidth="500" />  <!-- Grid panel -->
                <ColumnDefinition Width="4" />                                   <!-- Splitter -->
                <ColumnDefinition Width="*" />                                   <!-- Preview -->
                <ColumnDefinition Width="Auto" />                                <!-- Metadata -->
            </Grid.ColumnDefinitions>

            <!-- ── Grid panel ── -->
            <Border Grid.Column="0"
                    Background="{StaticResource BgFilmstripBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,0">
                <DockPanel>
                    <!-- Header: label + zoom slider -->
                    <Border DockPanel.Dock="Top"
                            Background="{StaticResource BgToolbarBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="8,4">
                        <DockPanel>
                            <TextBlock Text="GRID"
                                       Foreground="{StaticResource TextDimBrush}"
                                       FontSize="10"
                                       VerticalAlignment="Center"
                                       DockPanel.Dock="Left"
                                       Margin="0,0,8,0" />
                            <TextBlock Text="+"
                                       Foreground="{StaticResource TextDimBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       DockPanel.Dock="Right"
                                       Margin="4,0,0,0" />
                            <TextBlock Text="−"
                                       Foreground="{StaticResource TextDimBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       DockPanel.Dock="Left"
                                       Margin="0,0,4,0" />
                            <Slider Minimum="1" Maximum="8"
                                    Value="{Binding GridColumnCount}"
                                    IsDirectionReversed="True"
                                    VerticalAlignment="Center"
                                    SmallChange="1"
                                    LargeChange="1" />
                        </DockPanel>
                    </Border>

                    <!-- Thumbnail grid -->
                    <ListBox x:Name="GridView"
                             SizeChanged="GridView_SizeChanged"
                             ItemsSource="{Binding FilteredPhotos}"
                             SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}"
                             ItemContainerStyle="{StaticResource FilmstripItemStyle}"
                             SelectionChanged="GridView_SelectionChanged"
                             PreviewMouseWheel="GridView_PreviewMouseWheel"
                             PreviewMouseRightButtonDown="PhotoList_PreviewMouseRightButtonDown"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             VirtualizingPanel.IsVirtualizing="False">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid x:Name="GridItemsPanel" Columns="2" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:PhotoItem}">
                                <StackPanel Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <StackPanel.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Tags"
                                                      ItemsSource="{Binding PlacementTarget.Tag.SelectedPhotoTagAssignments, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                <MenuItem.ItemContainerStyle>
                                                    <Style TargetType="MenuItem">
                                                        <Setter Property="Header" Value="{Binding Tag.Name}" />
                                                        <Setter Property="IsCheckable" Value="True" />
                                                        <Setter Property="IsChecked" Value="{Binding IsAssigned, Mode=OneWay}" />
                                                        <Setter Property="Command" Value="{Binding PlacementTarget.Tag.ToggleTagForSelectedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                        <Setter Property="CommandParameter" Value="{Binding Tag}" />
                                                    </Style>
                                                </MenuItem.ItemContainerStyle>
                                            </MenuItem>
                                            <Separator />
                                            <MenuItem Header="New Tag…"
                                                      Command="{Binding PlacementTarget.Tag.CreateTagCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <Separator />
                                            <MenuItem Header="Delete…"
                                                      Command="{Binding PlacementTarget.Tag.DeletePhotoCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        </ContextMenu>
                                    </StackPanel.ContextMenu>
                                    <Grid Height="{Binding DataContext.GridThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}">
                                        <!-- Stack-of-cards backers: same-sized cards offset diagonally behind main -->
                                        <Border Background="#FF141414"
                                                BorderBrush="#FF2A2A2A"
                                                BorderThickness="1"
                                                Margin="0,0,8,8"
                                                Visibility="{Binding CollapsedBurstCount, Converter={StaticResource NullToVisibility}}" />
                                        <Border Background="#FF1A1A1A"
                                                BorderBrush="#FF333333"
                                                BorderThickness="1"
                                                Margin="4,4,4,4"
                                                Visibility="{Binding CollapsedBurstCount, Converter={StaticResource NullToVisibility}}" />

                                        <Border Background="#FF0E0E0E"
                                                Margin="8,8,0,0"
                                                MouseLeftButtonUp="GridItem_MouseLeftButtonUp">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CollapsedBurstCount, Converter={StaticResource NullToVisibility}}" Value="Visible">
                                                        <Setter Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect BlurRadius="6" ShadowDepth="2" Direction="315" Opacity="0.55" Color="Black" />
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Image Source="{Binding ThumbnailJpeg, Converter={StaticResource ThumbBytesToImage}}"
                                                   Stretch="Uniform"
                                                   SnapsToDevicePixels="True"
                                                   RenderOptions.BitmapScalingMode="LowQuality" />
                                            <Rectangle Width="3"
                                                       HorizontalAlignment="Left"
                                                       Fill="{Binding Flag, Converter={StaticResource FlagToBrush}}" />
                                            <Ellipse Width="8" Height="8"
                                                     HorizontalAlignment="Right" VerticalAlignment="Top"
                                                     Margin="0,4,4,0"
                                                     Fill="{Binding ColorLabel, Converter={StaticResource LabelToBrush}}" />
                                            <Border HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                    Background="#A0000000"
                                                    Padding="4,1" Margin="2"
                                                    CornerRadius="2"
                                                    Visibility="{Binding Rating, Converter={StaticResource NullToVisibility}}">
                                                <TextBlock Text="{Binding Rating, Converter={StaticResource RatingToStars}}"
                                                           Foreground="{StaticResource StarBrush}"
                                                           FontSize="10" />
                                            </Border>
                                            <!-- Tag indicator -->
                                            <Border HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                    Background="#CC007ACC"
                                                    Padding="4,1" Margin="2"
                                                    CornerRadius="2"
                                                    Visibility="{Binding TagDisplay, Converter={StaticResource NullToVisibility}}">
                                                <TextBlock Text="{Binding TagDisplay}"
                                                           Foreground="White"
                                                           FontSize="9" />
                                            </Border>
                                            <!-- Burst position badge: only shown when expanded -->
                                            <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                                                    Background="#CC9C27B0"
                                                    Padding="4,1" Margin="6,4,0,0"
                                                    CornerRadius="2"
                                                    ToolTip="Burst position">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding CollapsedBurstCount}" Value="0" />
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Visibility" Value="{Binding BurstBadge, Converter={StaticResource NullToVisibility}}" />
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding BurstBadge}"
                                                           Foreground="White"
                                                           FontSize="9" />
                                            </Border>
                                            <!-- Collapsed-burst count badge: only when collapsed -->
                                            <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                                                    Background="#E69C27B0"
                                                    Padding="4,1" Margin="6,4,0,0"
                                                    CornerRadius="2"
                                                    ToolTip="Burst — double-click to focus"
                                                    Visibility="{Binding CollapsedBurstCount, Converter={StaticResource NullToVisibility}}">
                                                <TextBlock Foreground="White" FontSize="10" FontWeight="SemiBold">
                                                    <Run Text="×" /><Run Text="{Binding CollapsedBurstCount, Mode=OneWay}" />
                                                </TextBlock>
                                            </Border>
                                            <!-- Video indicator -->
                                            <Border HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                                    Background="#CC000000"
                                                    Padding="4,1" Margin="0,0,0,2"
                                                    CornerRadius="2"
                                                    ToolTip="Video"
                                                    Visibility="{Binding IsVideo, Converter={StaticResource NullToVisibility}}">
                                                <TextBlock Text="▶" Foreground="White" FontSize="9" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                    </Grid>
                                    <TextBlock Text="{Binding FileName}"
                                               Foreground="{StaticResource TextDimBrush}"
                                               FontSize="10"
                                               TextTrimming="CharacterEllipsis"
                                               Padding="2,2,2,0" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}"
                          Cursor="SizeWE" />

            <!-- Preview area -->
            <Grid Grid.Column="2" Background="#FF0E0E0E">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0"
                        x:Name="PreviewHost"
                        Background="Transparent"
                        ClipToBounds="True"
                        Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                        MouseWheel="PreviewHost_MouseWheel"
                        MouseLeftButtonDown="PreviewHost_MouseLeftButtonDown"
                        MouseLeftButtonUp="PreviewHost_MouseLeftButtonUp"
                        MouseMove="PreviewHost_MouseMove">
                    <Border.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Tags"
                                      ItemsSource="{Binding PlacementTarget.Tag.SelectedPhotoTagAssignments, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                <MenuItem.ItemContainerStyle>
                                    <Style TargetType="MenuItem">
                                        <Setter Property="Header" Value="{Binding Tag.Name}" />
                                        <Setter Property="IsCheckable" Value="True" />
                                        <Setter Property="IsChecked" Value="{Binding IsAssigned, Mode=OneWay}" />
                                        <Setter Property="Command" Value="{Binding PlacementTarget.Tag.ToggleTagForSelectedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <Setter Property="CommandParameter" Value="{Binding Tag}" />
                                    </Style>
                                </MenuItem.ItemContainerStyle>
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="New Tag…"
                                      Command="{Binding PlacementTarget.Tag.CreateTagCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            <Separator />
                            <MenuItem Header="Delete…"
                                      Command="{Binding PlacementTarget.Tag.DeletePhotoCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        </ContextMenu>
                    </Border.ContextMenu>
                    <Grid>
                        <Image x:Name="PreviewImageElement"
                               Source="{Binding PreviewImage}"
                               Stretch="Uniform"
                               SnapsToDevicePixels="True"
                               RenderOptions.BitmapScalingMode="Linear"
                               Margin="8"
                               RenderTransformOrigin="0,0"
                               Visibility="{Binding VideoSourceUri, Converter={StaticResource NotNullToCollapsed}}">
                            <Image.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="PreviewScale" ScaleX="1" ScaleY="1" />
                                    <TranslateTransform x:Name="PreviewTranslate" X="0" Y="0" />
                                </TransformGroup>
                            </Image.RenderTransform>
                        </Image>
                        <MediaElement x:Name="VideoPlayer"
                                      Source="{Binding VideoSourceUri}"
                                      LoadedBehavior="Manual"
                                      UnloadedBehavior="Manual"
                                      ScrubbingEnabled="True"
                                      Stretch="Uniform"
                                      Margin="8"
                                      MediaOpened="VideoPlayer_MediaOpened"
                                      MediaEnded="VideoPlayer_MediaEnded"
                                      MediaFailed="VideoPlayer_MediaFailed"
                                      Visibility="{Binding VideoSourceUri, Converter={StaticResource NullToVisibility}}" />
                    </Grid>
                </Border>

                <!-- Empty-state overlay -->
                <TextBlock Text="Press Ctrl+O to open a folder of RAW photos"
                           Foreground="{StaticResource TextDimBrush}"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"
                           Visibility="{Binding SelectedPhoto, Converter={StaticResource NotNullToCollapsed}}" />

                <!-- Loading indicator -->
                <Border Background="#A0000000"
                        Padding="16,10"
                        CornerRadius="4"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,16,0,0"
                        IsHitTestVisible="False"
                        Visibility="{Binding IsLoading, Converter={StaticResource NullToVisibility}}">
                    <TextBlock Text="Loading…" Foreground="{StaticResource TextBrush}" />
                </Border>

                <!-- Star rating + tag overlays (top-right of preview) -->
                <StackPanel HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,16,16,0"
                            IsHitTestVisible="False"
                            Visibility="{Binding SelectedPhoto, Converter={StaticResource NullToVisibility}}">
                    <Border Background="#80000000"
                            Padding="8,4"
                            CornerRadius="3"
                            Margin="0,0,0,4">
                        <TextBlock Text="{Binding SelectedPhoto.Rating, Converter={StaticResource RatingToStars}}"
                                   Foreground="{StaticResource StarBrush}"
                                   FontSize="18"
                                   FontWeight="Bold" />
                    </Border>
                    <Border Background="#CC007ACC"
                            Padding="8,4"
                            CornerRadius="3"
                            Visibility="{Binding SelectedPhoto.TagDisplay, Converter={StaticResource NullToVisibility}}">
                        <TextBlock Text="{Binding SelectedPhoto.TagDisplay}"
                                   Foreground="White"
                                   FontSize="12" />
                    </Border>
                </StackPanel>

                <!-- Zoom indicator (bottom-right) -->
                <Border Grid.Row="0"
                        Background="#80000000"
                        Padding="6,2"
                        CornerRadius="3"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,16,16"
                        IsHitTestVisible="False"
                        x:Name="ZoomIndicator"
                        Visibility="Collapsed">
                    <TextBlock x:Name="ZoomIndicatorText"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="11" />
                </Border>

                <!-- Video playback controls (visible only when a video is loaded) -->
                <Border Grid.Row="1"
                        Background="{StaticResource BgToolbarBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="8,6"
                        Visibility="{Binding VideoSourceUri, Converter={StaticResource NullToVisibility}}">
                    <DockPanel LastChildFill="True">
                        <Button x:Name="VideoPlayPauseButton"
                                DockPanel.Dock="Left"
                                Content="▶"
                                Width="32"
                                Margin="0,0,8,0"
                                Click="VideoPlayPause_Click"
                                ToolTip="Play / Pause (Space)" />
                        <TextBlock x:Name="VideoTimeText"
                                   DockPanel.Dock="Right"
                                   Text="0:00 / 0:00"
                                   Foreground="{StaticResource TextDimBrush}"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"
                                   FontFamily="Consolas" />
                        <Button x:Name="VideoMuteButton"
                                DockPanel.Dock="Right"
                                Content="🔊"
                                Width="32"
                                Margin="8,0,0,0"
                                Click="VideoMute_Click"
                                ToolTip="Mute / Unmute" />
                        <Slider x:Name="VideoSlider"
                                Minimum="0"
                                Maximum="1"
                                Value="0"
                                VerticalAlignment="Center"
                                IsMoveToPointEnabled="True"
                                Thumb.DragStarted="VideoSlider_DragStarted"
                                Thumb.DragCompleted="VideoSlider_DragCompleted"
                                ValueChanged="VideoSlider_ValueChanged" />
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Metadata panel -->
            <Border Grid.Column="3"
                    Width="280"
                    Background="{StaticResource BgPanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="140" MinHeight="80" />
                        <RowDefinition Height="4" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Histogram + channel toggle -->
                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <controls:HistogramControl Grid.Row="0"
                                                   Data="{Binding HistogramData}"
                                                   ShowRgb="{Binding ShowRgbHistogram}" />
                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,4"
                                    Visibility="{Binding HistogramData, Converter={StaticResource NullToVisibility}}">
                            <ToggleButton Content="RGB" Command="{Binding ShowRgbHistogramModeCommand}"
                                          FontSize="10" Padding="8,2" Margin="0,0,2,0">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
                                        <Setter Property="IsChecked" Value="False" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowRgbHistogram}" Value="True">
                                                <Setter Property="IsChecked" Value="True" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>
                            <ToggleButton Content="All" Command="{Binding ShowCombinedHistogramModeCommand}"
                                          FontSize="10" Padding="8,2">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
                                        <Setter Property="IsChecked" Value="False" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowRgbHistogram}" Value="False">
                                                <Setter Property="IsChecked" Value="True" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>
                        </StackPanel>
                    </Grid>

                    <!-- Resize handle -->
                    <GridSplitter Grid.Row="1"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  Background="{StaticResource BorderBrush}"
                                  Cursor="SizeNS" />

                    <!-- Metadata scroll area -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <TextBlock Text="PHOTO" Foreground="{StaticResource TextDimBrush}" FontSize="10" Margin="0,0,0,6" />
                        <TextBlock Text="{Binding SelectedPhoto.FileName, FallbackValue='(no selection)'}"
                                   FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,12" />

                        <!-- Flags / labels -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="14" Height="14" CornerRadius="2"
                                    Background="{Binding SelectedPhoto.Flag, Converter={StaticResource FlagToBrush}}"
                                    Margin="0,0,8,0" />
                            <TextBlock Text="{Binding SelectedPhoto.Flag, FallbackValue=''}" Margin="0,0,12,0" />
                            <Ellipse Width="10" Height="10"
                                     Fill="{Binding SelectedPhoto.ColorLabel, Converter={StaticResource LabelToBrush}}"
                                     Margin="0,0,6,0" />
                            <TextBlock Text="{Binding SelectedPhoto.ColorLabel, FallbackValue=''}" />
                        </StackPanel>

                        <TextBlock Text="CAMERA" Foreground="{StaticResource TextDimBrush}" FontSize="10" Margin="0,0,0,6" />
                        <TextBlock Text="{Binding SelectedPhoto.Metadata.CameraModel, FallbackValue='—'}" Margin="0,0,0,2" />
                        <TextBlock Text="{Binding SelectedPhoto.Metadata.LensModel,   FallbackValue=''}"
                                   Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,12" />

                        <TextBlock Text="EXPOSURE" Foreground="{StaticResource TextDimBrush}" FontSize="10" Margin="0,0,0,6" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="ISO " Foreground="{StaticResource TextDimBrush}" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedPhoto.Metadata.ISOFormatted, FallbackValue='—'}" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Aperture " Foreground="{StaticResource TextDimBrush}" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedPhoto.Metadata.ApertureFormatted, FallbackValue='—'}" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Shutter " Foreground="{StaticResource TextDimBrush}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedPhoto.Metadata.ShutterSpeedFormatted, FallbackValue='—'}" />
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Focal " Foreground="{StaticResource TextDimBrush}" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedPhoto.Metadata.FocalLengthFormatted, FallbackValue='—'}" />
                        </Grid>

                        <TextBlock Text="BURST" Foreground="{StaticResource TextDimBrush}" FontSize="10" Margin="0,0,0,6"
                                   Visibility="{Binding SelectedPhoto.BurstBadge, Converter={StaticResource NullToVisibility}}" />
                        <TextBlock Text="{Binding SelectedPhoto.BurstBadge, FallbackValue=''}" Margin="0,0,0,12"
                                   Visibility="{Binding SelectedPhoto.BurstBadge, Converter={StaticResource NullToVisibility}}" />

                        <TextBlock Text="DATE" Foreground="{StaticResource TextDimBrush}" FontSize="10" Margin="0,0,0,6" />
                        <TextBlock Text="{Binding SelectedPhotoCaptureDateFormatted, FallbackValue='—'}" Margin="0,0,0,12" />

                        <TextBlock Text="FILE" Foreground="{StaticResource TextDimBrush}" FontSize="10" Margin="0,0,0,6" />
                        <TextBlock Text="{Binding SelectedPhoto.Extension, FallbackValue=''}" />
                        <TextBlock Text="{Binding SelectedPhoto.FilePath, FallbackValue=''}"
                                   Foreground="{StaticResource TextDimBrush}"
                                   TextWrapping="Wrap" FontSize="10" Margin="0,4,0,0" />

                        <Separator Margin="0,16" />

                        <TextBlock Text="SHORTCUTS" Foreground="{StaticResource TextDimBrush}" FontSize="10" Margin="0,0,0,6" />
                        <TextBlock Text="←/→  Navigate" Margin="0,1" />
                        <TextBlock Text="Ctrl+←/→  Jump burst" Margin="0,1" />
                        <TextBlock Text="0–5  Rating" Margin="0,1" />
                        <TextBlock Text="6–9  Color label" Margin="0,1" />
                        <TextBlock Text="P / X  Pick / Reject" Margin="0,1" />
                        <TextBlock Text="⇧+P / ⇧+X  Flag &amp; advance" Margin="0,1" />
                        <TextBlock Text="U  Unflag" Margin="0,1" />
                        <TextBlock Text="⇧+1–0  Assign tag" Margin="0,1" />
                        <TextBlock Text="Ctrl+O  Open folder" Margin="0,1" />
                        <TextBlock Text="Ctrl+C  Copy picks" Margin="0,1" />
                    </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ================ FILMSTRIP SPLITTER ================ -->
        <GridSplitter Grid.Row="2"
                      Height="4"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="{StaticResource BorderBrush}"
                      Cursor="SizeNS" />

        <!-- ================ FILMSTRIP ================ -->
        <Border Grid.Row="3"
                Background="{StaticResource BgFilmstripBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,1">
            <ListBox x:Name="Filmstrip"
                     ItemsSource="{Binding FilteredPhotos}"
                     SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}"
                     ItemContainerStyle="{StaticResource FilmstripItemStyle}"
                     SelectionChanged="Filmstrip_SelectionChanged"
                     PreviewMouseWheel="Filmstrip_PreviewMouseWheel"
                     PreviewMouseRightButtonDown="PhotoList_PreviewMouseRightButtonDown"
                     SizeChanged="Filmstrip_SizeChanged">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:PhotoItem}">
                        <Grid Width="{Binding DataContext.FilmstripItemWidth, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0"
                              Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                            <Grid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Tags"
                                              ItemsSource="{Binding PlacementTarget.Tag.SelectedPhotoTagAssignments, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                        <MenuItem.ItemContainerStyle>
                                            <Style TargetType="MenuItem">
                                                <Setter Property="Header" Value="{Binding Tag.Name}" />
                                                <Setter Property="IsCheckable" Value="True" />
                                                <Setter Property="IsChecked" Value="{Binding IsAssigned, Mode=OneWay}" />
                                                <Setter Property="Command" Value="{Binding PlacementTarget.Tag.ToggleTagForSelectedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                <Setter Property="CommandParameter" Value="{Binding Tag}" />
                                            </Style>
                                        </MenuItem.ItemContainerStyle>
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Header="New Tag…"
                                              Command="{Binding PlacementTarget.Tag.CreateTagCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <Separator />
                                    <MenuItem Header="Delete…"
                                              Command="{Binding PlacementTarget.Tag.DeletePhotoCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                </ContextMenu>
                            </Grid.ContextMenu>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Thumbnail area -->
                            <Grid Grid.Row="0">
                                <!-- Stack-of-cards backers: same-sized cards offset diagonally behind main -->
                                <Border Background="#FF141414"
                                        BorderBrush="#FF2A2A2A"
                                        BorderThickness="1"
                                        Margin="0,0,8,8"
                                        Visibility="{Binding CollapsedBurstCount, Converter={StaticResource NullToVisibility}}" />
                                <Border Background="#FF1A1A1A"
                                        BorderBrush="#FF333333"
                                        BorderThickness="1"
                                        Margin="4,4,4,4"
                                        Visibility="{Binding CollapsedBurstCount, Converter={StaticResource NullToVisibility}}" />
                            <Border Background="#FF0E0E0E"
                                    Margin="8,8,0,0"
                                    MouseLeftButtonUp="FilmstripItem_MouseLeftButtonUp">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CollapsedBurstCount, Converter={StaticResource NullToVisibility}}" Value="Visible">
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect BlurRadius="6" ShadowDepth="2" Direction="315" Opacity="0.55" Color="Black" />
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Image Source="{Binding ThumbnailJpeg, Converter={StaticResource ThumbBytesToImage}}"
                                           Stretch="Uniform"
                                           SnapsToDevicePixels="True"
                                           RenderOptions.BitmapScalingMode="LowQuality" />

                                    <!-- Flag bar (left edge) -->
                                    <Rectangle Width="3"
                                               HorizontalAlignment="Left"
                                               Fill="{Binding Flag, Converter={StaticResource FlagToBrush}}" />

                                    <!-- Color label dot (top-right) -->
                                    <Ellipse Width="8" Height="8"
                                             HorizontalAlignment="Right" VerticalAlignment="Top"
                                             Margin="0,4,4,0"
                                             Fill="{Binding ColorLabel, Converter={StaticResource LabelToBrush}}" />

                                    <!-- Stars (bottom-left) -->
                                    <Border HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                            Background="#A0000000"
                                            Padding="4,1" Margin="2"
                                            CornerRadius="2"
                                            Visibility="{Binding Rating, Converter={StaticResource NullToVisibility}}">
                                        <TextBlock Text="{Binding Rating, Converter={StaticResource RatingToStars}}"
                                                   Foreground="{StaticResource StarBrush}"
                                                   FontSize="10" />
                                    </Border>
                                    <!-- Tag indicator (bottom-right) -->
                                    <Border HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                            Background="#CC007ACC"
                                            Padding="4,1" Margin="2"
                                            CornerRadius="2"
                                            Visibility="{Binding TagDisplay, Converter={StaticResource NullToVisibility}}">
                                        <TextBlock Text="{Binding TagDisplay}"
                                                   Foreground="White"
                                                   FontSize="9" />
                                    </Border>
                                    <!-- Burst position badge: only shown when expanded -->
                                    <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                                            Background="#CC9C27B0"
                                            Padding="4,1" Margin="6,4,0,0"
                                            CornerRadius="2"
                                            ToolTip="Burst position">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding CollapsedBurstCount}" Value="0" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="{Binding BurstBadge, Converter={StaticResource NullToVisibility}}" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding BurstBadge}"
                                                   Foreground="White"
                                                   FontSize="9" />
                                    </Border>
                                    <!-- Collapsed-burst count badge: only when collapsed -->
                                    <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                                            Background="#E69C27B0"
                                            Padding="4,1" Margin="6,4,0,0"
                                            CornerRadius="2"
                                            ToolTip="Burst — double-click to focus"
                                            Visibility="{Binding CollapsedBurstCount, Converter={StaticResource NullToVisibility}}">
                                        <TextBlock Foreground="White" FontSize="10" FontWeight="SemiBold">
                                            <Run Text="×" /><Run Text="{Binding CollapsedBurstCount, Mode=OneWay}" />
                                        </TextBlock>
                                    </Border>
                                    <!-- Video indicator -->
                                    <Border HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                            Background="#CC000000"
                                            Padding="4,1" Margin="0,0,0,2"
                                            CornerRadius="2"
                                            ToolTip="Video"
                                            Visibility="{Binding IsVideo, Converter={StaticResource NullToVisibility}}">
                                        <TextBlock Text="▶" Foreground="White" FontSize="9" />
                                    </Border>
                                </Grid>
                            </Border>
                            </Grid>

                            <!-- Filename -->
                            <TextBlock Grid.Row="1"
                                       Text="{Binding FileName}"
                                       Foreground="{StaticResource TextDimBrush}"
                                       FontSize="10"
                                       TextTrimming="CharacterEllipsis"
                                       Padding="2,2,2,0" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- ================ STATUS BAR ================ -->
        <Border Grid.Row="4"
                Background="{StaticResource BgToolbarBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="8,4">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding CurrentFolder}"
                           Foreground="{StaticResource TextDimBrush}"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextBrush}" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
