<Application x:Class="Rawr.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Rawr.App.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/DarkTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <conv:JpegBytesToImageConverter x:Key="ThumbBytesToImage" DecodePixelWidth="240" />
            <conv:CullFlagToBrushConverter x:Key="FlagToBrush" />
            <conv:ColorLabelToBrushConverter x:Key="LabelToBrush" />
            <conv:RatingToStarsConverter x:Key="RatingToStars" />
            <conv:NullToVisibilityConverter x:Key="NullToVisibility" />
            <conv:NullToVisibilityConverter x:Key="NotNullToCollapsed" Invert="True" />
            <conv:EqualityConverter x:Key="Equality" />
            <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
